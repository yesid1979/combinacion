<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Combinacion App</display-name>

    <!-- 1. CONFIGURACIÓN DEL FILTRO DE SEGURIDAD -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.combinacion.util.AuthFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 2. DECLARACIÓN DE SERVLETS -->
    
    <!-- Login y Logout -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Contratistas -->
    <servlet>
        <servlet-name>ContratistaServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.ContratistaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContratistaServlet</servlet-name>
        <url-pattern>/contratistas</url-pattern>
    </servlet-mapping>

    <!-- Supervisores -->
    <servlet>
        <servlet-name>SupervisorServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.SupervisorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SupervisorServlet</servlet-name>
        <url-pattern>/supervisores</url-pattern>
    </servlet-mapping>

    <!-- Contratos -->
    <servlet>
        <servlet-name>ContratoServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.ContratoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContratoServlet</servlet-name>
        <url-pattern>/contratos</url-pattern>
    </servlet-mapping>

    <!-- Usuarios (CORREGIDO: /admin/usuarios) -->
    <servlet>
        <servlet-name>UsuarioServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.UsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsuarioServlet</servlet-name>
        <url-pattern>/admin/usuarios</url-pattern>
        <url-pattern>/usuarios</url-pattern>
    </servlet-mapping>

    <!-- Roles -->
    <servlet>
        <servlet-name>RolServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.RolServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RolServlet</servlet-name>
        <url-pattern>/admin/roles</url-pattern>
    </servlet-mapping>

    <!-- Presupuestos -->
    <servlet>
        <servlet-name>PresupuestoServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.PresupuestoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PresupuestoServlet</servlet-name>
        <url-pattern>/presupuesto</url-pattern>
    </servlet-mapping>

    <!-- Ordenadores -->
    <servlet>
        <servlet-name>OrdenadorServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.OrdenadorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrdenadorServlet</servlet-name>
        <url-pattern>/ordenadores</url-pattern>
    </servlet-mapping>

    <!-- Combinación -->
    <servlet>
        <servlet-name>CombinacionServlet</servlet-name>
        <servlet-class>com.combinacion.servlets.CombinacionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CombinacionServlet</servlet-name>
        <url-pattern>/combinacion</url-pattern>
    </servlet-mapping>

    <!-- 3. OTROS RECURSOS -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <resource-ref>
        <description>DB Connection</description>
        <res-ref-name>jdbc/combinacion</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>
